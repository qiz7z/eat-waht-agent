# ==================================================
# 大模型统一配置
# 优先级：LLM_* > OPENAI_* > DASHSCOPE_*
# ==================================================

# 推荐使用：通用 OpenAI-Compatible 配置
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=15

# ==================================================
# OpenAI 配置（也兼容 DeepSeek / Kimi / 智谱 / LM Studio 等 OpenAI-Compatible 服务）
# ==================================================
# OPENAI_API_KEY=your_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek 示例
# OPENAI_API_KEY=your_deepseek_key_here
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com

# 本地模型示例：LM Studio / Ollama OpenAI-compatible
# OPENAI_API_KEY=local-key
# OPENAI_MODEL=local-model
# OPENAI_BASE_URL=http://localhost:1234/v1

# ==================================================
# 通义千问 OpenAI 兼容模式
# ==================================================
# DASHSCOPE_API_KEY=your_dashscope_key_here
# DASHSCOPE_MODEL=qwen-turbo
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================================================
# 代理配置（可选，如需通过代理访问 API）
# ==================================================
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# ==================================================
# 应用配置
# ==================================================
APP_NAME=吃什么推荐助手
APP_VERSION=1.0.0

# ==================================================
# 日志配置
# ==================================================
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=agent.log
